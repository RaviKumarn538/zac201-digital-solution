
<% layout('/layouts/boilerplate') -%>

                    
<body>
       
      <div class="container">
        <div class="row">
          <% for(let listing of allistings){ %>
            <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
              <div class="card h-100">
                <a href="/listing/<%= listing._id %>">
                  <img src="<%= listing.img %>" class="card-img-top" alt="<%= listing.title %>">
                </a>
                <div class="card-body">
                  <h5 class="card-title">
                    <%= listing.title %>
                  </h5>
                  <p class="card-text price">₹<%= listing.price %>
                  </p>
                  <p class="card-text location">
                    <%= listing.location %>
                  </p>
                </div>
              </div>
            </div>
            <% } %>
        </div>
      </div>
</body>
</html>