
<% layout('/layouts/boilerplate') -%>

 <head>
<body> 
<h2 class="edit-heading">Edit Listing</h2>

<div class="edit-container">
<form method="post" action="/listing/<%= listing._id %>?_method=put" novalidate class="needs-validation">

    <div class="form-group">
        <label for="title">Title</label>
        <input type="text" id="title" name="listing[title]" value="<%= listing.title %>" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter title.</div>
    </div>

    <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="listing[description]" rows="4" required minlength="5"><%= listing.description %></textarea>
        <div class="invalid-feedback">Please enter description.</div>
    </div>

    <div class="form-group">
        <label for="img">Image URL</label>
        <input type="text" id="img" name="listing[img]" value="<%= listing.img %>">
    </div>

    <div class="form-group">
        <label for="price">Price (per month)</label>
        <input type="number" id="price" name="listing[price]" value="<%= listing.price %>" required>
        <div class="invalid-feedback">Please enter price.</div>
    </div>

    <div class="form-group">
        <label for="location">Location (Area)</label>
        <input type="text" id="location" name="listing[location]" value="<%= listing.location %>" required>
        <div class="invalid-feedback">Please enter location.</div>
    </div>

    <div class="form-group">
        <label for="city">City</label>
        <input type="text" id="city" name="listing[city]" value="<%= listing.city %>" required>
        <div class="invalid-feedback">Please enter city.</div>
    </div>

    <button type="submit" class="update-btn">Update Listing</button>
</form>
</div>
    <script src="/js/script.js"></script>
</body>
</html>