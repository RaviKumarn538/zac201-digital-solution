<% layout('/layouts/boilerplate') -%>

<section class="container dashboard-head max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
  <div class="min-w-0">
    <span class="eyebrow">Student dashboard</span>
    <h1>Hi <%= user.name %>, your Bhopal room matches are ready.</h1>
    <p>Recommended rooms are below. We will contact you on WhatsApp for suitable options and visit support.</p>
  </div>
  <a href="/support/whatsapp" class="btn btn-primary w-full sm:w-auto">WhatsApp Support</a>
</section>

<section class="container dashboard-grid max-w-7xl px-4 sm:px-6 lg:px-8 grid grid-cols-1 gap-4 md:grid-cols-3">
  <div class="dash-panel">
    <h2>My profile</h2>
    <p><strong><%= user.name %></strong></p>
    <p class="muted"><%= user.phone %><% if (user.email) { %> | <%= user.email %><% } %></p>
    <p class="muted"><%= user.occupation || "Student/working not added" %><% if (user.institute) { %> at <%= user.institute %><% } %></p>
    <a href="/profile" class="btn btn-outline-primary btn-sm">Edit profile</a>
    <% if (!user.preferencesComplete) { %>
      <a href="/preferences?step=1" class="btn btn-primary btn-sm mt-2">Complete room preferences</a>
    <% } %>
  </div>
  <div class="dash-panel">
    <h2>My room requirements</h2>
    <p><strong><%= user.preferredArea || "Area not added" %></strong> | <%= user.budgetRange || "Budget not added" %></p>
    <p class="muted"><%= user.roomType || "Any room" %> | Food: <%= user.foodRequired || "Any" %> | Safety: <%= user.safetyPriority || "Normal" %></p>
    <p class="muted"><%= user.specialRequirements || "No special requirements added." %></p>
  </div>
  <div class="dash-panel">
    <h2>Inquiry status</h2>
    <% if (!requests.length) { %><p class="muted">No visit requests yet.</p><% } %>
    <% requests.forEach((request) => { %>
      <div class="mini-row">
        <span><%= request.room ? request.room.title : "Room removed" %></span>
        <strong><%= request.status %></strong>
      </div>
    <% }) %>
  </div>
</section>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <h2>Recommended rooms</h2>
    <a href="/rooms" class="text-link">Browse all</a>
  </div>
  <div class="room-grid grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
    <% recommendedRooms.forEach((room) => { %>
      <%- include("../partials_room_card", { room }) %>
    <% }) %>
    <%- include("../partials_see_all_card") %>
  </div>
</section>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <h2>Saved rooms</h2>
    <span class="muted"><%= savedRooms.length %> shortlisted</span>
  </div>
  <% if (!savedRooms.length) { %><div class="empty-state">Save rooms from the listing page to shortlist them here.</div><% } %>
  <div class="room-grid grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
    <% savedRooms.forEach((room) => { %>
      <%- include("../partials_room_card", { room }) %>
    <% }) %>
  </div>
</section>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <h2>Visit requests</h2>
  </div>
  <div class="interest-list grid grid-cols-1 gap-4 md:grid-cols-3">
    <% requests.forEach((request) => { %>
      <div class="interest-card">
        <span class="eyebrow"><%= request.status %></span>
        <h3><%= request.room ? request.room.title : "Room removed" %></h3>
        <p class="muted">Requested on <%= request.createdAt %></p>
        <p><%= request.message %></p>
      </div>
    <% }) %>
  </div>
</section>
