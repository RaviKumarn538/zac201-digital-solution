<% layout('/layouts/boilerplate') -%>

<section class="container dashboard-head max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
  <div class="min-w-0">
    <span class="eyebrow">Private admin dashboard</span>
    <h1>Manage Zac.Living listings and student inquiries.</h1>
    <p>Add PGs and rooms, track owner details, update availability, publish or hide listings, and review student leads.</p>
  </div>
  <div class="admin-head-actions">
    <span class="status-badge <%= dbStatus === 'Connected' ? '' : 'full' %>">DB: <%= dbStatus %></span>
    <a href="/admin/rooms/new" class="btn btn-primary w-full sm:w-auto">Add new listing</a>
  </div>
</section>

<section class="container admin-stats max-w-7xl px-4 sm:px-6 lg:px-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-6">
  <div class="dash-panel">
    <span class="muted">Total listings</span>
    <strong><%= stats.totalRooms %></strong>
  </div>
  <div class="dash-panel">
    <span class="muted">Showing now</span>
    <strong><%= stats.visibleRooms %></strong>
  </div>
  <div class="dash-panel">
    <span class="muted">Published</span>
    <strong><%= stats.publishedRooms %></strong>
  </div>
  <div class="dash-panel">
    <span class="muted">Available</span>
    <strong><%= stats.availableRooms %></strong>
  </div>
  <div class="dash-panel">
    <span class="muted">Pending visits</span>
    <strong><%= stats.pendingRequests %></strong>
  </div>
  <div class="dash-panel">
    <span class="muted">Zac audit</span>
    <strong><%= stats.pendingAuditRooms %></strong>
  </div>
</section>

<% if (ownerSubmissions.length) { %>
  <section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <span class="eyebrow">Owner submissions</span>
        <h2>New properties from List Your Property</h2>
        <span class="muted"><%= ownerSubmissions.length %> waiting in your admin workspace</span>
      </div>
      <a href="/admin?published=pending" class="btn btn-outline-primary btn-sm">View pending filter</a>
    </div>

    <div class="admin-listing-table">
      <% ownerSubmissions.forEach((room) => { %>
        <article class="admin-listing-row">
          <div class="admin-listing-photo">
            <img src="<%= room.photo %>" alt="<%= room.title %>">
          </div>
          <div class="admin-listing-main">
            <div class="admin-listing-title">
              <div>
                <h3><%= room.title %></h3>
                <p class="muted">Rs. <%= room.rent.toLocaleString("en-IN") %>/mo | <%= room.area %> | <%= room.landmark %></p>
              </div>
              <div class="admin-badges">
                <span class="status-badge full">Owner submitted</span>
                <span class="status-badge few-beds-left"><%= room.auditStatus || "Pending Zac Audit" %></span>
              </div>
            </div>
            <div class="admin-owner-grid">
              <p><span>Owner</span><strong><%= room.ownerName || "Not added" %></strong></p>
              <p><span>Contact</span><strong><%= room.ownerContact || "Not added" %></strong></p>
              <p><span>Address</span><strong><%= room.ownerAddress || "Not added" %></strong></p>
              <p><span>Type</span><strong><%= room.category %> | <%= room.roomType %> | Food: <%= room.food %></strong></p>
            </div>
          </div>
          <div class="owner-actions admin-row-actions">
            <form method="post" action="/admin/rooms/<%= room.id %>/quick" class="w-full">
              <input type="hidden" name="published" value="true">
              <button class="btn btn-primary btn-sm w-full" type="submit">Publish</button>
            </form>
            <a href="/admin/rooms/<%= room.id %>/edit" class="btn btn-outline-primary btn-sm w-full">Edit</a>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h2>PG and room listings</h2>
      <span class="muted"><%= rooms.length %> visible with current filters</span>
    </div>
    <a href="/admin/rooms/new" class="btn btn-outline-primary btn-sm">Add listing</a>
  </div>

  <form method="get" action="/admin" class="admin-filter-bar">
    <input name="search" value="<%= filters.search || '' %>" placeholder="Search title, area, owner, phone, address">
    <select name="availability" aria-label="Filter by availability">
      <option value="">All availability</option>
      <% availabilityOptions.forEach((option) => { %>
        <option value="<%= option %>" <%= filters.availability === option ? "selected" : "" %>><%= option %></option>
      <% }) %>
    </select>
    <select name="published" aria-label="Filter by publish status">
      <option value="">All status</option>
      <option value="published" <%= filters.published === "published" ? "selected" : "" %>>Published</option>
      <option value="hidden" <%= filters.published === "hidden" ? "selected" : "" %>>Hidden</option>
      <option value="pending" <%= filters.published === "pending" ? "selected" : "" %>>Pending Zac Audit</option>
    </select>
    <select name="category" aria-label="Filter by category">
      <option value="">All categories</option>
      <option value="Boys" <%= filters.category === "Boys" ? "selected" : "" %>>Boys</option>
      <option value="Girls" <%= filters.category === "Girls" ? "selected" : "" %>>Girls</option>
    </select>
    <button class="btn btn-primary btn-sm" type="submit">Filter</button>
    <a class="btn btn-outline-primary btn-sm" href="/admin">Reset</a>
  </form>

  <% if (!rooms.length) { %>
    <div class="empty-state">No listings found. Add your first PG, room, or flat, or reset filters.</div>
  <% } %>

  <div class="admin-listing-table">
    <% rooms.forEach((room) => { %>
      <article class="admin-listing-row">
        <a href="/rooms/<%= room.id %>" class="admin-listing-photo">
          <img src="<%= room.photo %>" alt="<%= room.title %>">
        </a>
        <div class="admin-listing-main">
          <div class="admin-listing-title">
            <div>
              <h3><%= room.title %></h3>
              <p class="muted">Rs. <%= room.rent.toLocaleString("en-IN") %>/mo | Deposit Rs. <%= room.deposit.toLocaleString("en-IN") %> | <%= room.area %> | <%= room.landmark %></p>
            </div>
            <div class="admin-badges">
              <span class="status-badge <%= room.published ? '' : 'full' %>"><%= room.published ? "Published" : "Hidden" %></span>
              <span class="status-badge <%= room.availability === 'Full' ? 'full' : room.availability === 'Few beds left' ? 'few-beds-left' : '' %>"><%= room.availability %></span>
              <span class="status-badge <%= room.auditStatus === 'Pending Zac Audit' ? 'few-beds-left' : room.auditStatus === 'Rejected' ? 'full' : '' %>"><%= room.auditStatus || "Admin Added" %></span>
            </div>
          </div>

          <div class="admin-owner-grid">
            <p><span>Owner</span><strong><%= room.ownerName || "Not added" %></strong></p>
            <p><span>Contact</span><strong><%= room.ownerContact || "Not added" %></strong></p>
            <p><span>Address</span><strong><%= room.ownerAddress || "Not added" %></strong></p>
            <p><span>Type</span><strong><%= room.category %> | <%= room.roomType %> | Food: <%= room.food %></strong></p>
          </div>

          <div class="admin-inline-actions">
            <form method="post" action="/admin/rooms/<%= room.id %>/quick" class="quick-admin-form">
              <select name="availability" aria-label="Availability for <%= room.title %>">
                <% availabilityOptions.forEach((option) => { %>
                  <option value="<%= option %>" <%= room.availability === option ? "selected" : "" %>><%= option %></option>
                <% }) %>
              </select>
              <button class="btn btn-outline-primary btn-sm" type="submit">Save availability</button>
            </form>
            <form method="post" action="/admin/rooms/<%= room.id %>/quick">
              <input type="hidden" name="published" value="<%= room.published ? 'false' : 'true' %>">
              <button class="btn btn-outline-primary btn-sm" type="submit"><%= room.published ? "Unpublish" : "Publish" %></button>
            </form>
            <form method="post" action="/admin/rooms/<%= room.id %>/quick" class="quick-admin-form">
              <select name="auditStatus" aria-label="Audit status for <%= room.title %>">
                <% auditStatuses.forEach((status) => { %>
                  <option value="<%= status %>" <%= room.auditStatus === status ? "selected" : "" %>><%= status %></option>
                <% }) %>
              </select>
              <button class="btn btn-outline-primary btn-sm" type="submit">Save audit</button>
            </form>
          </div>
        </div>
        <div class="owner-actions admin-row-actions">
          <a href="/rooms/<%= room.id %>" class="btn btn-outline-primary btn-sm w-full">View</a>
          <a href="/admin/rooms/<%= room.id %>/edit" class="btn btn-outline-primary btn-sm w-full">Edit</a>
          <form method="post" action="/admin/rooms/<%= room.id %>?_method=delete" class="w-full">
            <button class="btn btn-danger btn-sm w-full" type="submit">Delete</button>
          </form>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <h2>Student signups and requirements</h2>
    <span class="muted"><%= students.length %> students</span>
  </div>

  <% if (!students.length) { %>
    <div class="empty-state">Student signups will appear here.</div>
  <% } %>

  <div class="interest-list grid grid-cols-1 gap-4 md:grid-cols-3">
    <% students.forEach((student) => { %>
      <div class="interest-card">
        <span class="eyebrow"><%= student.gender || "Student" %> | <%= student.occupation || "Requirement" %></span>
        <h3><%= student.name %></h3>
        <p class="muted"><%= student.phone || "No phone" %><% if (student.email) { %> | <%= student.email %><% } %></p>
        <p><strong>Requirement:</strong> <%= student.preferredArea || "Area not shared" %>, <%= student.budgetRange || "Budget not shared" %>, <%= student.roomType || "Any room" %>, Food: <%= student.foodRequired || "Any" %></p>
        <p class="muted"><%= student.specialRequirements || "No special notes." %></p>
        <p class="muted">Top match: <%= student.bestMatch ? student.bestMatch.title + " (" + student.bestMatch.match.label + ")" : "No published listings yet" %></p>
      </div>
    <% }) %>
  </div>
</section>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <h2>Visit requests</h2>
    <span class="muted"><%= requests.length %> inquiries</span>
  </div>

  <% if (!requests.length) { %>
    <div class="empty-state">Visit requests will appear here after students request a visit.</div>
  <% } %>

  <div class="interest-list grid grid-cols-1 gap-4 md:grid-cols-3">
    <% requests.forEach((request) => { %>
      <div class="interest-card">
        <span class="eyebrow"><%= request.status %></span>
        <h3><%= request.student ? request.student.name : "Student removed" %></h3>
        <p class="muted"><%= request.room ? request.room.title : "Room removed" %></p>
        <p><%= request.message %></p>
        <form method="post" action="/admin/requests/<%= request.id %>/status">
          <label for="status-<%= request.id %>">Update status</label>
          <select id="status-<%= request.id %>" name="status">
            <% inquiryStatuses.forEach((status) => { %>
              <option value="<%= status %>" <%= request.status === status ? "selected" : "" %>><%= status %></option>
            <% }) %>
          </select>
          <button class="btn btn-primary btn-sm mt-2" type="submit">Save status</button>
        </form>
      </div>
    <% }) %>
  </div>
</section>
