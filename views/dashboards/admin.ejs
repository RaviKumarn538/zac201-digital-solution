<% layout('/layouts/boilerplate') -%>

<section class="container dashboard-head max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
  <div class="min-w-0">
    <span class="eyebrow">Private admin dashboard</span>
    <h1>Manage Zac.Living listings and student inquiries.</h1>
    <p>Add listings, update availability, publish or hide rooms, review signups, and manage visit requests.</p>
  </div>
  <a href="/admin/rooms/new" class="btn btn-primary w-full sm:w-auto">Add new listing</a>
</section>

<section class="container admin-stats max-w-7xl px-4 sm:px-6 lg:px-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
  <div class="dash-panel">
    <span class="muted">Total listings</span>
    <strong><%= stats.totalRooms %></strong>
  </div>
  <div class="dash-panel">
    <span class="muted">Published</span>
    <strong><%= stats.publishedRooms %></strong>
  </div>
  <div class="dash-panel">
    <span class="muted">Students</span>
    <strong><%= stats.studentCount %></strong>
  </div>
  <div class="dash-panel">
    <span class="muted">Pending visits</span>
    <strong><%= stats.pendingRequests %></strong>
  </div>
</section>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <h2>Room listings</h2>
    <span class="muted"><%= rooms.length %> total</span>
  </div>

  <% if (!rooms.length) { %>
    <div class="empty-state">No listings yet. Add your first PG, room, or flat.</div>
  <% } %>

  <div class="owner-list">
    <% rooms.forEach((room) => { %>
      <div class="owner-row admin-room-row grid grid-cols-1 gap-3 sm:grid-cols-[112px_1fr] xl:grid-cols-[112px_1fr_auto]">
        <img src="<%= room.photo %>" alt="<%= room.title %>">
        <div class="min-w-0">
          <div class="room-card-top flex flex-col items-start gap-2 sm:flex-row sm:items-center sm:justify-between">
            <h3><%= room.title %></h3>
            <span class="status-badge <%= room.published ? '' : 'full' %>"><%= room.published ? "Published" : "Hidden" %></span>
          </div>
          <p class="muted">Rs. <%= room.rent.toLocaleString("en-IN") %>/mo | <%= room.area %> | <%= room.category %> | Food: <%= room.food %></p>
          <p class="muted">Availability: <%= room.availability %> | Internal owner contact: <%= room.ownerContact %></p>
          <form method="post" action="/admin/rooms/<%= room.id %>/quick" class="quick-admin-form grid grid-cols-1 gap-2 sm:grid-cols-[minmax(0,220px)_auto]">
            <select name="availability" aria-label="Availability for <%= room.title %>">
              <% availabilityOptions.forEach((option) => { %>
                <option value="<%= option %>" <%= room.availability === option ? "selected" : "" %>><%= option %></option>
              <% }) %>
            </select>
            <button class="btn btn-outline-primary btn-sm" type="submit">Update availability</button>
          </form>
        </div>
        <div class="owner-actions grid grid-cols-2 gap-2 sm:col-span-2 xl:col-span-1 xl:grid-cols-1">
          <a href="/rooms/<%= room.id %>" class="btn btn-outline-primary btn-sm w-full">View</a>
          <a href="/admin/rooms/<%= room.id %>/edit" class="btn btn-outline-primary btn-sm w-full">Edit</a>
          <form method="post" action="/admin/rooms/<%= room.id %>/quick" class="w-full">
            <input type="hidden" name="published" value="<%= room.published ? 'false' : 'true' %>">
            <button class="btn btn-outline-primary btn-sm w-full" type="submit"><%= room.published ? "Unpublish" : "Publish" %></button>
          </form>
          <form method="post" action="/admin/rooms/<%= room.id %>?_method=delete" class="w-full">
            <button class="btn btn-danger btn-sm w-full" type="submit">Delete</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <h2>Student signups and requirements</h2>
    <span class="muted"><%= students.length %> students</span>
  </div>

  <% if (!students.length) { %>
    <div class="empty-state">Student signups will appear here.</div>
  <% } %>

  <div class="interest-list grid grid-cols-1 gap-4 md:grid-cols-3">
    <% students.forEach((student) => { %>
      <div class="interest-card">
        <span class="eyebrow"><%= student.gender || "Student" %> | <%= student.occupation || "Requirement" %></span>
        <h3><%= student.name %></h3>
        <p class="muted"><%= student.phone || "No phone" %><% if (student.email) { %> | <%= student.email %><% } %></p>
        <p><strong>Requirement:</strong> <%= student.preferredArea || "Area not shared" %>, <%= student.budgetRange || "Budget not shared" %>, <%= student.roomType || "Any room" %>, Food: <%= student.foodRequired || "Any" %></p>
        <p class="muted"><%= student.specialRequirements || "No special notes." %></p>
        <p class="muted">Top match: <%= student.bestMatch ? student.bestMatch.title + " (" + student.bestMatch.match.label + ")" : "No published listings yet" %></p>
      </div>
    <% }) %>
  </div>
</section>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <h2>Visit requests</h2>
    <span class="muted"><%= requests.length %> inquiries</span>
  </div>

  <% if (!requests.length) { %>
    <div class="empty-state">Visit requests will appear here after students request a visit.</div>
  <% } %>

  <div class="interest-list grid grid-cols-1 gap-4 md:grid-cols-3">
    <% requests.forEach((request) => { %>
      <div class="interest-card">
        <span class="eyebrow"><%= request.status %></span>
        <h3><%= request.student ? request.student.name : "Student removed" %></h3>
        <p class="muted"><%= request.room ? request.room.title : "Room removed" %></p>
        <p><%= request.message %></p>
        <form method="post" action="/admin/requests/<%= request.id %>/status">
          <label for="status-<%= request.id %>">Update status</label>
          <select id="status-<%= request.id %>" name="status">
            <% inquiryStatuses.forEach((status) => { %>
              <option value="<%= status %>" <%= request.status === status ? "selected" : "" %>><%= status %></option>
            <% }) %>
          </select>
          <button class="btn btn-primary btn-sm mt-2" type="submit">Save status</button>
        </form>
      </div>
    <% }) %>
  </div>
</section>
