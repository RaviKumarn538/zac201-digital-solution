<% layout('/layouts/boilerplate') -%>

<section class="container page-head narrow">
  <span class="eyebrow">My profile</span>
  <h1>Update your room requirement.</h1>
  <p>These fields power Zac.Living recommendations and help support understand what you need.</p>
</section>

<section class="container profile-grid">
  <form method="post" action="/profile" class="app-form">
    <div class="form-row">
      <div>
        <label for="name">Full name</label>
        <input id="name" name="name" value="<%= user.name %>" required>
      </div>
      <div>
        <label for="phone">Mobile/WhatsApp number</label>
        <input id="phone" name="phone" value="<%= user.phone %>" required>
      </div>
    </div>

    <div class="form-row">
      <div>
        <label for="gender">Gender</label>
        <select id="gender" name="gender">
          <% genderOptions.forEach((option) => { %>
            <option value="<%= option %>" <%= user.gender === option ? "selected" : "" %>><%= option %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="occupation">Student or working professional</label>
        <select id="occupation" name="occupation">
          <option value="Student" <%= user.occupation === "Student" ? "selected" : "" %>>Student</option>
          <option value="Working Professional" <%= user.occupation === "Working Professional" ? "selected" : "" %>>Working Professional</option>
        </select>
      </div>
    </div>

    <label for="institute">College/coaching/company name</label>
    <input id="institute" name="institute" value="<%= user.institute %>" required>

    <div class="form-row">
      <div>
        <label for="preferredArea">Preferred area</label>
        <input id="preferredArea" name="preferredArea" value="<%= user.preferredArea %>" required>
      </div>
      <div>
        <label for="budgetRange">Budget range</label>
        <input id="budgetRange" name="budgetRange" value="<%= user.budgetRange %>" required>
      </div>
    </div>

    <div class="form-row">
      <div>
        <label for="foodRequired">Food required</label>
        <select id="foodRequired" name="foodRequired">
          <% foodOptions.forEach((option) => { %>
            <option value="<%= option %>" <%= user.foodRequired === option ? "selected" : "" %>><%= option %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="roomType">Room type</label>
        <select id="roomType" name="roomType">
          <% roomTypes.forEach((type) => { %>
            <option value="<%= type %>" <%= user.roomType === type ? "selected" : "" %>><%= type %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <label for="safetyPriority">Safety priority</label>
    <select id="safetyPriority" name="safetyPriority">
      <option value="Normal" <%= user.safetyPriority === "Normal" ? "selected" : "" %>>Normal</option>
      <option value="High" <%= user.safetyPriority === "High" ? "selected" : "" %>>High</option>
    </select>

    <label for="specialRequirements">Special requirements</label>
    <textarea id="specialRequirements" name="specialRequirements" rows="4"><%= user.specialRequirements || '' %></textarea>

    <button class="btn btn-primary w-100" type="submit">Save requirements</button>
  </form>

  <aside class="saved-panel">
    <h2>Saved rooms</h2>
    <% if (!savedRooms.length) { %>
      <p class="muted">You have not shortlisted any rooms yet.</p>
    <% } %>
    <% savedRooms.forEach((room) => { %>
      <a href="/rooms/<%= room.id %>" class="saved-room">
        <img src="<%= room.photo %>" alt="<%= room.title %>">
        <span><%= room.title %></span>
      </a>
    <% }) %>
  </aside>
</section>
