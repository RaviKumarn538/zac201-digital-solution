<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zac.Living</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link
                href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Space+Grotesk:wght@400;500;600;700&display=swap"
                rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css"> 
    <script>
      tailwind.config = {
        corePlugins: {
          preflight: false,
          visibility: false
        },
        theme: {
          extend: {
            fontFamily: {
              sans: ['"Plus Jakarta Sans"', 'Arial', 'sans-serif'],
              display: ['"Space Grotesk"', '"Plus Jakarta Sans"', 'Arial', 'sans-serif']
            }
          }
        }
      };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
         
    <%- include("../includes/navbar") %> 

    <main><%- body %></main>

    <%- include("../includes/footer") %>

    <section class="zac-ai-bot" data-zac-ai-bot aria-label="Zac AI helper">
        <button class="zac-ai-toggle" type="button" data-zac-ai-toggle aria-expanded="false">
            <i class="fa-solid fa-wand-magic-sparkles"></i>
            <span>Ask Zac</span>
        </button>
        <div class="zac-ai-panel" data-zac-ai-panel aria-hidden="true">
            <div class="zac-ai-head">
                <div>
                    <strong>Zac AI Helper</strong>
                    <span>Rooms, search, listing aur website help</span>
                </div>
                <button type="button" data-zac-ai-toggle aria-label="Close AI helper"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="zac-ai-messages" data-zac-ai-messages>
                <p class="zac-ai-message bot">Hi, apna budget, area ya room need likho. Main matching rooms suggest kar dunga.</p>
            </div>
            <form class="zac-ai-form" data-zac-ai-form>
                <input name="message" placeholder="Example: Girls PG under 8000 near AIIMS" autocomplete="off">
                <button type="submit" aria-label="Send"><i class="fa-solid fa-paper-plane"></i></button>
            </form>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
        <script src="/js/script.js?v=ai-tools-1"></script>
</body>
</html>
