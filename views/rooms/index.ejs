<% layout('/layouts/boilerplate') -%>

<section class="container page-head">
  <span class="eyebrow">Browse before signup</span>
  <h1>Compare PGs, rooms, and flats in Bhopal</h1>
  <p>Check rent, area, food, room type, availability, and video tours. Login is needed only when you save, request a visit, or get matched.</p>
</section>

<section class="container">
  <%- include("search_form", { query }) %>
</section>

<section class="container section-block">
  <% if (!rooms.length) { %>
    <div class="empty-state">No rooms matched your filters. Try a wider budget or another area.</div>
  <% } %>
  <div class="room-grid">
    <% rooms.forEach((room) => { %>
      <%- include("../partials_room_card", { room }) %>
    <% }) %>
  </div>
</section>
