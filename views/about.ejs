<% layout('/layouts/boilerplate') -%>

<section class="about-hero">
  <div class="container about-grid">
    <div class="about-copy">
      <span class="eyebrow">About Zac.Living</span>
      <h1>Helping Bhopal students find the right room with more trust and less stress.</h1>
      <p>Zac.Living is a Bhopal-based student room matching startup built to help students find suitable PGs, rooms, and flats without confusion. Many students come to Bhopal for college, coaching, internships, and work, but finding a safe, affordable, and comfortable place to stay is not always easy.</p>
      <p>Zac.Living solves this by showing room options with real details such as rent, area, food, facilities, rules, photos, video tours, and availability.</p>
    </div>
    <div class="about-stat-card">
      <span class="eyebrow">Mission</span>
      <h2>Search first. Compare clearly. Choose confidently.</h2>
      <p>Students can browse listings, save rooms, request visits, and get matched with places that fit their budget and lifestyle.</p>
    </div>
  </div>
</section>

<section class="container section-block" id="safety">
  <div class="section-heading">
    <div>
      <span class="eyebrow">Why Zac.Living?</span>
      <h2>Built around student decisions</h2>
    </div>
  </div>
  <div class="why-grid">
    <div class="why-card">
      <span>01</span>
      <h3>Real room details</h3>
      <p>Clear information about rent, facilities, food, room type, rules, and availability.</p>
    </div>
    <div class="why-card">
      <span>02</span>
      <h3>Student-focused matching</h3>
      <p>Find rooms based on area, budget, college/coaching location, food needs, and safety preference.</p>
    </div>
    <div class="why-card">
      <span>03</span>
      <h3>Photo and video support</h3>
      <p>Listings include photos and video tours so students can understand the room before visiting.</p>
    </div>
    <div class="why-card mission-card">
      <span>Bhopal first</span>
      <h3>Local discovery</h3>
      <p>Zac.Living starts with one simple mission: helping Bhopal students find suitable accommodation faster.</p>
    </div>
  </div>
</section>

<section class="container section-block" id="faq">
  <div class="section-heading">
    <div>
      <span class="eyebrow">FAQ</span>
      <h2>Common student questions</h2>
    </div>
  </div>
  <div class="why-grid">
    <div class="why-card">
      <span>Q</span>
      <h3>Can I browse without signup?</h3>
      <p>Yes. Students can explore rooms first. Signup is needed only for saving rooms, requesting visits, and matching support.</p>
    </div>
    <div class="why-card">
      <span>Q</span>
      <h3>Is Zac.Living only for Bhopal?</h3>
      <p>Yes, the MVP is focused on Bhopal student PGs, rooms, and flats.</p>
    </div>
  </div>
</section>
