<% layout('/layouts/boilerplate') -%>

<section class="auth-wrap px-4 py-6 sm:px-6">
  <form method="post" action="/login" class="app-form auth-card w-full max-w-md" novalidate>
    <span class="eyebrow">Student login</span>
    <h1>Login to find your room</h1>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <label for="phone">Mobile/WhatsApp number</label>
    <input id="phone" name="phone" inputmode="tel" value="<%= form.phone || '' %>" required placeholder="Example: 9876543210">

    <label for="password">Password</label>
    <input id="password" name="password" type="password" required placeholder="Enter your account password">

    <button class="btn btn-primary w-100" type="submit">Login</button>
    <p class="form-note">Use the WhatsApp number and password you added during signup.</p>
    <p class="form-note">New here? <a href="/signup">Create an account</a></p>
  </form>
</section>
