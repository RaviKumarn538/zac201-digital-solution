<% layout('/layouts/boilerplate') -%>

<section class="discovery-hero">
  <div class="container max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="discovery-copy max-w-4xl">
      <span class="eyebrow">Bhopal student housing</span>
      <h1>Find student PGs, rooms, and flats in Bhopal with real photos and video tours.</h1>
      <p>Zac.Living helps students compare room options by budget, area, food, facilities, rules, and availability. Explore first, sign up only when you want to save, request a visit, or get matched.</p>
    </div>

    <%- include("rooms/search_form", { query }) %>

    <div class="category-scroll" aria-label="Popular room categories">
      <a href="/rooms?area=MP+Nagar" class="category-chip">MP Nagar</a>
      <a href="/rooms?budget=8000" class="category-chip">Under Rs. 8k</a>
      <a href="/rooms?category=Girls" class="category-chip">Girls PG</a>
      <a href="/rooms?category=Boys" class="category-chip">Boys PG</a>
      <a href="/rooms?food=Yes" class="category-chip">With food</a>
      <a href="/rooms?video=Yes" class="category-chip">Video tour</a>
    </div>
  </div>
</section>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <span class="eyebrow"><%= isPersonalized ? "Based on your requirement" : "Start exploring" %></span>
      <h2><%= isPersonalized ? "Recommended rooms for you" : "Popular homes for students" %></h2>
    </div>
    <a href="/rooms" class="text-link">See all rooms</a>
  </div>
  <div class="room-grid grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
    <% featuredRooms.forEach((room) => { %>
      <%- include("partials_room_card", { room }) %>
    <% }) %>
  </div>
</section>

<section class="container section-block max-w-7xl px-4 sm:px-6 lg:px-8" id="how-it-works">
  <div class="section-heading flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <span class="eyebrow">How it works</span>
      <h2>Search first, sign up only when needed</h2>
    </div>
  </div>
  <div class="steps-grid grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-5">
    <div><strong>1</strong><span>Search by area, budget, room type, food, or category</span></div>
    <div><strong>2</strong><span>Browse photos, rent, facilities, rules, and video tours</span></div>
    <div><strong>3</strong><span>Open room details and compare options freely</span></div>
    <div><strong>4</strong><span>Sign up only when you save, request a visit, or need matching</span></div>
    <div><strong>5</strong><span>Choose the best room with Zac.Living support</span></div>
  </div>
</section>
